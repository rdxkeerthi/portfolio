---
import Layout from '../layouts/Layout.astro';
import HeroConsole from '../components/HeroConsole.jsx';
import RadarTechGrid from '../components/RadarTechGrid.jsx';
import EncryptedProjectCards from '../components/EncryptedProjectCards.jsx';

const timelineEvents = [
  {
    year: '2024 - PRESENT',
    event: 'CYBERSECURITY OPERATIONS & VAPT SPECIALIST',
    org: 'Enterprise Threat Management',
    desc: 'Performing regular vulnerability assessments and penetration testing. Auditing local networks and cloud resources to patch configurations and harden endpoints against intrusion vectors.'
  },
  {
    year: '2023 - 2024',
    event: 'SOC THREAT ANALYST & INCIDENT RESPONSE',
    org: 'Infrastructure Security Center',
    desc: 'Integrated log aggregation playbooks in Splunk. Analyzed firewall, web server, and auth syslog metrics to block SSH brute-forces and perform malware threat hunting.'
  },
  {
    year: '2021 - 2024',
    event: 'BS IN CYBER SECURITY & DIGITAL FORENSICS',
    org: 'Academic Institution',
    desc: 'Specialized in computer forensics, secure software lifecycle development, cryptography, database hardening, and network protocols security.'
  }
];
---

<Layout>
  <!-- Main Header Bar -->
  <header class="sticky top-0 z-[100] border-b border-white/[0.04] bg-[#050811]/75 backdrop-blur-xl select-none font-mono">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="#" class="font-bold text-sm tracking-widest flex items-center gap-2 group text-white uppercase">
        <span class="bg-gradient-to-r from-[#1E40AF] to-[#00F0FF] text-black px-2.5 py-1 rounded transition-all font-black text-xs shadow-[0_0_15px_rgba(0,240,255,0.15)]">SEC // OP</span>
        <span class="tracking-[0.12em] font-extrabold text-xs">Keerthivasan M</span>
      </a>
      <nav class="hidden md:flex gap-8 text-[10px] font-bold uppercase tracking-wider text-neutral-400">
        <a href="#about" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          PROFILE
        </a>
        <a href="#arsenal" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          ARSENAL
        </a>
        <a href="#projects" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          PROJECTS
        </a>
        <a href="#timeline" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          LOGS
        </a>
        <a href="#contact" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          CONTACT
        </a>
      </nav>
    </div>
  </header>

  <!-- Hero Landing Section -->
  <section id="about" class="border-b border-white/[0.04] overflow-hidden">
    <HeroConsole client:load />
  </section>

  <!-- Tech Arsenal Section -->
  <section id="arsenal" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.04] overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/5 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/15 select-none">
            01 // CAPABILITIES
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Tooling <span class="text-[#00F0FF]">&</span> Secure Arsenal
        </h2>
      </div>
      <RadarTechGrid client:load />
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section id="projects" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.04] overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/5 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/15 select-none">
            02 // SECURED VAULTS
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Secured <span class="text-[#00F0FF]">Dossiers</span> & Projects
        </h2>
      </div>
      <EncryptedProjectCards client:load />
    </div>
  </section>

  <!-- Secure Log Timeline Section -->
  <section id="timeline" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.04] overflow-hidden">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/5 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/15 select-none">
            03 // CHRONOLOGY
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Milestones <span class="text-[#00F0FF]">&</span> Timeline
        </h2>
      </div>

      <!-- Log Timeline Core (Alternating Layout) -->
      <div class="relative max-w-5xl mx-auto px-4 overflow-hidden">
        <!-- Central Line (Desktop Only, Left-aligned on Mobile) -->
        <div class="absolute left-6 md:left-1/2 md:-translate-x-1/2 top-2 bottom-2 w-[2px] bg-white/5">
          <div class="traceroute-line w-full bg-[#00F0FF]/60 shadow-[0_0_8px_rgba(0,240,255,0.4)]" style="height: 0%;"></div>
        </div>

        <div class="space-y-16">
          {timelineEvents.map((log, index) => {
            const isLeft = index % 2 === 0;
            return (
              <div class={`timeline-event opacity-25 flex flex-col md:flex-row items-center w-full relative ${isLeft ? 'md:justify-start' : 'md:justify-end'}`}>
              <!-- Center Node Dot -->
              <div class="absolute left-6 md:left-1/2 -translate-x-1/2 top-6 md:top-1/2 md:-translate-y-1/2 bg-[#050811] border border-white/20 w-4 h-4 rounded-full flex items-center justify-center z-10 transition-all duration-300">
                <div class="w-1.5 h-1.5 bg-[#00F0FF] rounded-full"></div>
              </div>

              <!-- Event Card Container -->
              <div class={`w-full md:w-[45%] pl-12 md:pl-0 ${isLeft ? 'md:pr-8' : 'md:pl-8'}`}>
                <div class="glass-panel p-6 sm:p-8 border border-white/5 rounded-3xl bg-black/10 hover:border-[#00F0FF]/20 transition-all duration-500 hover:scale-[1.02]">
                <div class="flex flex-wrap items-center justify-between gap-2 border-b border-white/5 pb-2.5 mb-3.5 font-mono text-[9px]">
                  <span class="text-neutral-500 font-bold">{log.year}</span>
                  <span class="text-[#00F0FF] uppercase tracking-wider bg-[#00F0FF]/5 px-2 py-0.5 rounded border border-[#00F0FF]/15">
                    VERIFIED_RECORD
                  </span>
                </div>

                {/* Event Name */}
                <h3 class="font-sans text-sm sm:text-base font-bold text-white mb-1 tracking-tight">
                  {log.event}
                </h3>
                <span class="font-mono text-[10px] text-neutral-400 block mb-3 uppercase tracking-wider font-semibold">
                  {log.org}
                </span>

                {/* Description */}
                <p class="text-xs text-neutral-400 leading-relaxed font-sans font-medium">
                  {log.desc}
                </p>
              </div>
            </div>
          </div>
          );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="relative py-24 px-6 sm:px-12 md:px-24 overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/5 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/15 select-none">
            04 // TRANSMISSIONS
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Initialize <span class="text-[#00F0FF]">Transmission</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        {/* Contact Form */}
        <div class="lg:col-span-8">
          <form 
            onsubmit="event.preventDefault(); alert('Transmission broadcasted successfully.');"
            class="space-y-8 glass-panel p-8 sm:p-10 rounded-3xl bg-black/10 relative overflow-hidden"
          >
            <div class="border-b border-white/5 pb-4 mb-4 font-mono text-[9px] text-neutral-500 uppercase tracking-widest">
              <span>Secure Mail Gateway</span>
            </div>

            {/* Name input */}
            <div class="relative group">
              <label for="name" class="block font-mono text-[10px] uppercase font-black tracking-widest mb-2 text-neutral-400">
                Identity
              </label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                placeholder="e.g. Operator Name"
                class="w-full bg-black/30 border-b border-white/10 px-0 py-3.5 font-sans text-sm focus:outline-none transition-all text-white placeholder:text-neutral-700"
              />
              <span class="absolute bottom-0 left-1/2 w-0 h-[2px] bg-[#00F0FF] transition-all duration-500 origin-center -translate-x-1/2 group-focus-within:w-full shadow-[0_0_8px_rgba(0,240,255,0.7)]"></span>
            </div>

            {/* Email input */}
            <div class="relative group">
              <label for="email" class="block font-mono text-[10px] uppercase font-black tracking-widest mb-2 text-neutral-400">
                Return Vector (Email)
              </label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                placeholder="e.g. operator@domain.com"
                class="w-full bg-black/30 border-b border-white/10 px-0 py-3.5 font-sans text-sm focus:outline-none transition-all text-white placeholder:text-neutral-700"
              />
              <span class="absolute bottom-0 left-1/2 w-0 h-[2px] bg-[#00F0FF] transition-all duration-500 origin-center -translate-x-1/2 group-focus-within:w-full shadow-[0_0_8px_rgba(0,240,255,0.7)]"></span>
            </div>

            {/* Message input */}
            <div class="relative group">
              <label for="message" class="block font-mono text-[10px] uppercase font-black tracking-widest mb-2 text-neutral-400">
                Transmission Body
              </label>
              <textarea 
                id="message" 
                name="message" 
                rows="4" 
                required 
                placeholder="Type secure transmission..."
                class="w-full bg-black/30 border-b border-white/10 px-0 py-3.5 font-sans text-sm focus:outline-none transition-all text-white placeholder:text-neutral-700 resize-none"
              ></textarea>
              <span class="absolute bottom-0 left-1/2 w-0 h-[2px] bg-[#00F0FF] transition-all duration-500 origin-center -translate-x-1/2 group-focus-within:w-full shadow-[0_0_8px_rgba(0,240,255,0.7)]"></span>
            </div>

            {/* Submit Button */}
            <button 
              type="submit"
              class="w-full bg-[#1E40AF]/25 hover:bg-[#00F0FF] text-white hover:text-black font-mono text-xs uppercase font-extrabold tracking-widest border border-[#1E40AF]/40 hover:border-[#00F0FF] py-4 rounded-xl transition-all duration-300 shadow-[0_0_15px_rgba(0,240,255,0.05)] hover:shadow-[0_0_20px_rgba(0,240,255,0.3)] flex items-center justify-center gap-2 cursor-pointer"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
              </svg>
              Transmit Signal
            </button>
          </form>
        </div>

        {/* Sidebar with Live Website Viewer Fingerprint details */}
        <div class="lg:col-span-4 flex flex-col justify-between">
          <div class="glass-panel p-6 rounded-2xl border border-white/5 bg-black/10 space-y-4 mb-6">
            <h3 class="font-mono text-xs font-bold uppercase border-b border-white/5 pb-2 text-[#00F0FF] tracking-wider">
              CLIENT SYSTEM METRICS
            </h3>
            <ul class="font-mono text-[10px] space-y-3.5 text-neutral-400">
              <li>
                <span class="text-neutral-500 uppercase text-[8px] block tracking-wide">Visitor OS / Agent</span>
                <span id="metric-agent" class="font-bold text-white block truncate">Detecting...</span>
              </li>
              <li>
                <span class="text-neutral-500 uppercase text-[8px] block tracking-wide">Screen Resolution</span>
                <span id="metric-resolution" class="font-bold text-white block">Detecting...</span>
              </li>
              <li>
                <span class="text-neutral-500 uppercase text-[8px] block tracking-wide">Client Timezone</span>
                <span id="metric-timezone" class="font-bold text-white block">Detecting...</span>
              </li>
              <li>
                <span class="text-neutral-500 uppercase text-[8px] block tracking-wide">Preferred Lang</span>
                <span id="metric-lang" class="font-bold text-white block">Detecting...</span>
              </li>
              <li>
                <span class="text-neutral-500 uppercase text-[8px] block tracking-wide">Dynamic User Fingerprint Hash</span>
                <span id="metric-hash" class="font-bold text-[#00F0FF] block font-mono">Compiling...</span>
              </li>
            </ul>
          </div>

          <div class="glass-panel p-6 rounded-2xl border border-white/5 bg-black/10 space-y-4">
            <h3 class="font-mono text-xs font-bold uppercase border-b border-white/5 pb-2 text-[#00F0FF] tracking-wider">
              SECURE CHANNELS
            </h3>
            <div class="flex flex-col gap-3 font-mono text-[10px]">
              <a href="https://linkedin.com" target="_blank" class="glass-card p-3 flex items-center gap-3 border border-white/5 hover:border-[#00F0FF]/20 hover:shadow-[0_0_15px_rgba(0,240,255,0.08)] transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" class="text-[#00F0FF]"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                <span>LinkedIn</span>
              </a>
              <a href="https://github.com" target="_blank" class="glass-card p-3 flex items-center gap-3 border border-white/5 hover:border-[#00F0FF]/20 hover:shadow-[0_0_15px_rgba(0,240,255,0.08)] transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" class="text-[#00F0FF]"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                <span>GitHub</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GSAP Timeline & Client Fingerprint Controllers -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
      // Timeline path animation
      const line = document.querySelector('.traceroute-line');
      if (line) {
        gsap.to(line, {
          height: '100%',
          ease: 'none',
          scrollTrigger: {
            trigger: '#timeline',
            start: 'top center',
            end: 'bottom center',
            scrub: true
          }
        });
      }

      // Timeline nodes reveal (Alternating slide & fade animation)
      const events = document.querySelectorAll('.timeline-event');
      events.forEach((event, idx) => {
        const isLeft = idx % 2 === 0;
        const xOffset = window.innerWidth >= 768 ? (isLeft ? -40 : 40) : 0;

        // Set initial state
        gsap.set(event, { x: xOffset, opacity: 0.1 });

        gsap.to(event, {
          x: 0,
          opacity: 1,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: event,
            start: 'top 85%',
            end: 'bottom 15%',
            toggleActions: 'play none none reverse'
          }
        });
      });

      // Browser Fingerprinting script
      const agentEl = document.getElementById('metric-agent');
      const resEl = document.getElementById('metric-resolution');
      const tzEl = document.getElementById('metric-timezone');
      const langEl = document.getElementById('metric-lang');
      const hashEl = document.getElementById('metric-hash');

      if (agentEl) {
        const ua = navigator.userAgent;
        let os = "Unknown OS";
        if (ua.indexOf("Win") !== -1) os = "Windows";
        else if (ua.indexOf("Mac") !== -1) os = "macOS";
        else if (ua.indexOf("X11") !== -1) os = "UNIX";
        else if (ua.indexOf("Linux") !== -1) os = "Linux";
        else if (/Android/i.test(ua)) os = "Android";
        else if (/iPhone|iPad/i.test(ua)) os = "iOS";

        let browser = "Unknown Browser";
        if (ua.indexOf("Chrome") !== -1) browser = "Chrome";
        else if (ua.indexOf("Firefox") !== -1) browser = "Firefox";
        else if (ua.indexOf("Safari") !== -1) browser = "Safari";
        else if (ua.indexOf("Edge") !== -1) browser = "Edge";

        agentEl.textContent = `${os} / ${browser}`;
      }

      if (resEl) {
        resEl.textContent = `${window.screen.width}x${window.screen.height} (${window.devicePixelRatio}dppx)`;
      }

      if (tzEl) {
        try {
          tzEl.textContent = Intl.DateTimeFormat().resolvedOptions().timeZone || "UTC/Greenwich";
        } catch(e) {
          tzEl.textContent = "UTC/Greenwich";
        }
      }

      if (langEl) {
        langEl.textContent = (navigator.language || 'en-US').toUpperCase();
      }

      if (hashEl) {
        const fingerprintStr = navigator.userAgent + (navigator.language || 'en-US') + window.screen.width + window.screen.height + (Intl.DateTimeFormat().resolvedOptions().timeZone || "");
        
        // Simple hash compiler
        let hash = 5381;
        for (let i = 0; i < fingerprintStr.length; i++) {
          hash = (hash * 33) ^ fingerprintStr.charCodeAt(i);
        }
        const hexHash = Math.abs(hash).toString(16).toUpperCase().padStart(8, '0');
        hashEl.textContent = `0x${hexHash}-FP-ACTIVE`;
      }
    });
  </script>
</Layout>
