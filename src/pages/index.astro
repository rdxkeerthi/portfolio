---
import Layout from '../layouts/Layout.astro';
import HeroConsole from '../components/HeroConsole.jsx';
import RadarTechGrid from '../components/RadarTechGrid.jsx';
import EncryptedProjectCards from '../components/EncryptedProjectCards.jsx';

const timelineEvents = [
  {
    timestamp: '2024-06-15 08:30:00',
    year: '2024 - PRESENT',
    level: 'INFO',
    event: 'CYBERSECURITY OPERATIONS & VAPT SPECIALIST',
    org: 'Enterprise Threat Management',
    desc: 'Performing regular vulnerability assessments and penetration testing. Auditing local networks and cloud resources to patch configurations and harden endpoints against intrusion vectors.'
  },
  {
    timestamp: '2023-11-10 14:15:22',
    year: '2023 - 2024',
    level: 'SEC_AUDIT',
    event: 'SOC THREAT ANALYST & INCIDENT RESPONSE',
    org: 'Infrastructure Security Center',
    desc: 'Integrated log aggregation playbooks in Splunk. Analyzed firewall, web server, and auth syslog metrics to block SSH brute-forces and perform malware threat hunting.'
  },
  {
    timestamp: '2021-09-01 09:00:00',
    year: '2021 - 2024',
    level: 'SYS_INIT',
    event: 'BACHELOR OF SCIENCE - CYBER SECURITY & DIGITAL FORENSICS',
    org: 'Academic Institution',
    desc: 'Specialized in computer forensics, secure software lifecycle development, cryptography, database hardening, and network protocols security.'
  }
];
---

<Layout>
  <!-- Main Header Bar -->
  <header class="sticky top-0 z-[100] border-b border-white/[0.06] bg-[#0B0F19]/75 backdrop-blur-xl select-none font-mono">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="#" class="font-bold text-sm tracking-widest flex items-center gap-2 group text-white uppercase">
        <span class="bg-gradient-to-r from-[#1E40AF] to-[#00F0FF] text-white px-2.5 py-1 rounded transition-all font-black text-xs shadow-[0_0_15px_rgba(0,240,255,0.2)]">SEC // OP</span>
        <span class="tracking-[0.15em] font-extrabold text-xs">Keerthivasan M</span>
      </a>
      <nav class="hidden md:flex gap-8 text-[10px] font-bold uppercase tracking-wider text-neutral-400">
        <a href="#about" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          <span>// 01.</span> PROFILE
        </a>
        <a href="#arsenal" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          <span>// 02.</span> ARSENAL
        </a>
        <a href="#projects" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          <span>// 03.</span> PROJECTS
        </a>
        <a href="#timeline" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          <span>// 04.</span> LOGS
        </a>
        <a href="#contact" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1">
          <span>// 05.</span> COMM_CHANNEL
        </a>
      </nav>
    </div>
  </header>

  <!-- Hero Landing Section -->
  <section id="about" class="border-b border-white/[0.06] overflow-hidden">
    <HeroConsole client:load />
  </section>

  <!-- Tech Arsenal Section -->
  <section id="arsenal" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.06] overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/10 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/25 select-none">
            02 // Technical Capabilities
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Tooling <span class="text-[#00F0FF]">&</span> Secure Arsenal
        </h2>
      </div>
      <RadarTechGrid client:load />
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section id="projects" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.06] overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/10 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/25 select-none">
            03 // Vault Logs
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Secured <span class="text-[#00F0FF]">Dossiers</span> & Projects
        </h2>
      </div>
      <EncryptedProjectCards client:load />
    </div>
  </section>

  <!-- Secure Log Timeline Section -->
  <section id="timeline" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.06] overflow-hidden">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/10 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/25 select-none">
            04 // Log Readout
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Milestones <span class="text-[#00F0FF]">&</span> Event Logs
        </h2>
      </div>

      <!-- Log Timeline Core -->
      <div class="relative pl-6 sm:pl-10 md:pl-16">
        <!-- GSAP Scroll-animated traceroute line -->
        <div class="absolute left-[8px] sm:left-[12px] md:left-[18px] top-2 bottom-2 w-[2px] bg-white/10">
          <div class="traceroute-line w-full bg-[#00F0FF] shadow-[0_0_10px_rgba(0,240,255,0.7)]" style="height: 0%;"></div>
        </div>

        <div class="space-y-12">
          {timelineEvents.map((log) => (
            <div class="timeline-event opacity-20 relative select-none">
              <!-- Dot Indicator -->
              <div class="absolute -left-[27px] sm:-left-[35px] md:-left-[43px] top-3 bg-[#0B0F19] border-2 border-white/20 w-4 h-4 rounded-full flex items-center justify-center z-10 transition-all duration-300 group-hover:border-[#00F0FF]">
                <div class="w-1.5 h-1.5 bg-[#00F0FF] rounded-full"></div>
              </div>

              <!-- Log Entry Panel -->
              <div class="glass-panel p-6 border border-white/5 rounded-2xl bg-black/40">
                {/* Timestamp header */}
                <div class="flex flex-wrap items-center justify-between gap-2 border-b border-white/5 pb-3 mb-4 font-mono text-[10px]">
                  <span class="text-neutral-500 font-bold">[ {log.timestamp} ]</span>
                  <span class={`font-black uppercase tracking-wider px-2 py-0.5 rounded ${
                    log.level === 'SYS_INIT' 
                      ? 'bg-neutral-800 text-neutral-400' 
                      : log.level === 'SEC_AUDIT' 
                        ? 'bg-[#1E40AF]/25 text-[#00F0FF] border border-[#00F0FF]/10' 
                        : 'bg-[#00F0FF]/10 text-white'
                  }`}>
                    {log.level}
                  </span>
                </div>

                {/* Event Name */}
                <h3 className="font-mono text-sm sm:text-base font-bold text-white mb-1 tracking-tight">
                  {log.event}
                </h3>
                <span class="font-mono text-[11px] text-neutral-400 block mb-3 font-semibold">
                  {log.org}
                </span>

                {/* Description */}
                <p class="text-xs text-neutral-300 leading-relaxed font-sans font-medium">
                  {log.desc}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="relative py-24 px-6 sm:px-12 md:px-24 overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/10 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/25 select-none">
            05 // Comm Channel
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Initialize <span class="text-[#00F0FF]">Transmission</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        {/* Contact Form */}
        <div class="lg:col-span-8">
          <form 
            onsubmit="event.preventDefault(); alert('Transmission broadcasted successfully.');"
            class="space-y-8 glass-panel p-8 sm:p-10 rounded-3xl bg-black/40 relative overflow-hidden"
          >
            <div class="border-b border-white/5 pb-4 mb-4 font-mono text-[10px] text-neutral-500 uppercase tracking-widest">
              <span>Secure Mail Gateway</span>
            </div>

            {/* Name input */}
            <div class="relative group">
              <label for="name" class="block font-mono text-[10px] uppercase font-black tracking-widest mb-2 text-neutral-400">
                Identity
              </label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                placeholder="e.g. Operator Name"
                class="w-full bg-black/30 border-b border-white/10 px-0 py-3.5 font-mono text-sm focus:outline-none transition-all text-white placeholder:text-neutral-700"
              />
              <span class="absolute bottom-0 left-1/2 w-0 h-[2px] bg-[#00F0FF] transition-all duration-500 origin-center -translate-x-1/2 group-focus-within:w-full shadow-[0_0_8px_rgba(0,240,255,0.7)]"></span>
            </div>

            {/* Email input */}
            <div class="relative group">
              <label for="email" class="block font-mono text-[10px] uppercase font-black tracking-widest mb-2 text-neutral-400">
                Return Vector (Email)
              </label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                placeholder="e.g. operator@domain.com"
                class="w-full bg-black/30 border-b border-white/10 px-0 py-3.5 font-mono text-sm focus:outline-none transition-all text-white placeholder:text-neutral-700"
              />
              <span class="absolute bottom-0 left-1/2 w-0 h-[2px] bg-[#00F0FF] transition-all duration-500 origin-center -translate-x-1/2 group-focus-within:w-full shadow-[0_0_8px_rgba(0,240,255,0.7)]"></span>
            </div>

            {/* Message input */}
            <div class="relative group">
              <label for="message" class="block font-mono text-[10px] uppercase font-black tracking-widest mb-2 text-neutral-400">
                Transmission Payload
              </label>
              <textarea 
                id="message" 
                name="message" 
                rows="4" 
                required 
                placeholder="Type secure transmission..."
                class="w-full bg-black/30 border-b border-white/10 px-0 py-3.5 font-mono text-sm focus:outline-none transition-all text-white placeholder:text-neutral-700 resize-none"
              ></textarea>
              <span class="absolute bottom-0 left-1/2 w-0 h-[2px] bg-[#00F0FF] transition-all duration-500 origin-center -translate-x-1/2 group-focus-within:w-full shadow-[0_0_8px_rgba(0,240,255,0.7)]"></span>
            </div>

            {/* Submit Button */}
            <button 
              type="submit"
              class="w-full bg-[#1E40AF]/20 hover:bg-[#00F0FF] text-white hover:text-black font-mono text-xs uppercase font-extrabold tracking-widest border border-[#1E40AF]/50 hover:border-[#00F0FF] py-4 rounded-xl transition-all duration-300 shadow-[0_0_15px_rgba(30,64,175,0.1)] hover:shadow-[0_0_20px_rgba(0,240,255,0.4)] flex items-center justify-center gap-2 cursor-pointer"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="animate-pulse">
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
              </svg>
              Transmit Signal
            </button>
          </form>
        </div>

        {/* Sidebar */}
        <div class="lg:col-span-4 flex flex-col justify-between">
          <div class="glass-panel p-6 rounded-2xl border border-white/5 bg-black/20 space-y-4 mb-6">
            <h3 class="font-mono text-xs font-bold uppercase border-b border-white/5 pb-2 text-[#00F0FF]">
              SYSTEM METRICS
            </h3>
            <ul class="font-mono text-[11px] space-y-3 text-neutral-400">
              <li>
                <span class="text-neutral-600 uppercase text-[9px] block">Clearance</span>
                <span class="font-bold text-white">LEVEL_3 // UNRESTRICTED</span>
              </li>
              <li>
                <span class="text-neutral-600 uppercase text-[9px] block">Encryption</span>
                <span class="font-bold text-white">AES-256 GCM ACTIVE</span>
              </li>
              <li>
                <span class="text-neutral-600 uppercase text-[9px] block">Availability</span>
                <span class="font-bold text-white">OPEN TO PROPOSALS</span>
              </li>
            </ul>
          </div>

          <div class="glass-panel p-6 rounded-2xl border border-white/5 bg-black/20 space-y-4">
            <h3 class="font-mono text-xs font-bold uppercase border-b border-white/5 pb-2 text-[#00F0FF]">
              SECURE CHANNELS
            </h3>
            <div class="flex flex-col gap-3 font-mono text-[11px]">
              <a href="https://linkedin.com" target="_blank" class="glass-card p-3 flex items-center gap-3 border border-white/5 hover:border-[#00F0FF]/30 hover:shadow-[0_0_15px_rgba(0,240,255,0.15)] transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" class="text-[#00F0FF]"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                <span>LinkedIn</span>
              </a>
              <a href="https://github.com" target="_blank" class="glass-card p-3 flex items-center gap-3 border border-white/5 hover:border-[#00F0FF]/30 hover:shadow-[0_0_15px_rgba(0,240,255,0.15)] transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" class="text-[#00F0FF]"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                <span>GitHub</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GSAP Timeline Controller -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
      // Traceroute line drawing animation
      const line = document.querySelector('.traceroute-line');
      if (line) {
        gsap.to(line, {
          height: '100%',
          ease: 'none',
          scrollTrigger: {
            trigger: '#timeline',
            start: 'top center',
            end: 'bottom center',
            scrub: true
          }
        });
      }

      // Timeline events lighting up
      const events = document.querySelectorAll('.timeline-event');
      events.forEach((event) => {
        gsap.to(event, {
          opacity: 1,
          scrollTrigger: {
            trigger: event,
            start: 'top 75%',
            end: 'bottom 25%',
            toggleActions: 'play none none reverse'
          }
        });
      });
    });
  </script>
</Layout>
