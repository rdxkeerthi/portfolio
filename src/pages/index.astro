  <!-- GSAP Timeline & Client Fingerprint Controllers -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
      // Timeline path animation
      const line = document.querySelector('.traceroute-line');
      if (line) {
        gsap.to(line, {
          height: '100%',
          ease: 'none',
          scrollTrigger: {
            trigger: '#timeline',
            start: 'top center',
            end: 'bottom center',
            scrub: true
          }
        });
      }

      // Timeline nodes reveal (Alternating slide & fade animation)
      const events = document.querySelectorAll('.timeline-event');
      events.forEach((event, idx) => {
        const isLeft = idx % 2 === 0;
        const xOffset = window.innerWidth >= 768 ? (isLeft ? -40 : 40) : 0;

        // Set initial state
        gsap.set(event, { x: xOffset, opacity: 0.1 });

        gsap.to(event, {
          x: 0,
          opacity: 1,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: event,
            start: 'top 85%',
            end: 'bottom 15%',
            toggleActions: 'play none none reverse'
          }
        });
      });

      // Contact Form submission with Web3Forms + mailto fallback
      const form = document.getElementById('contact-form') as HTMLFormElement;
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
          const originalText = submitBtn.innerHTML;
          submitBtn.disabled = true;
          submitBtn.innerHTML = 'Broadcasting...';

          const formData = new FormData(form);
          const name = formData.get('name') as string;
          const email = formData.get('email') as string;
          const message = formData.get('message') as string;
          const accessKey = formData.get('access_key') as string;

          if (!accessKey || accessKey === 'YOUR_ACCESS_KEY_HERE' || accessKey.trim() === '') {
            submitBtn.innerHTML = 'Redirecting...';
            setTimeout(() => {
              const subject = encodeURIComponent(`Secure Transmission from ${name}`);
              const body = encodeURIComponent(`Identity: ${name}\nReturn Vector: ${email}\n\nTransmission:\n${message}`);
              window.location.href = `mailto:keerthivasanm.student@saveetha.ac.in?subject=${subject}&body=${body}`;
              submitBtn.disabled = false;
              submitBtn.innerHTML = originalText;
              alert('Web3Forms access key not found. Redirecting to system mail client fallback...');
            }, 500);
            return;
          }

          try {
            const response = await fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              body: formData
            });
            const data = await response.json();
            if (data.success) {
              alert('Transmission broadcasted successfully via Web3Forms gateway.');
              form.reset();
            } else {
              throw new Error(data.message || 'Submission API Rejected');
            }
          } catch (error) {
            console.error('Submission error:', error);
            alert('API Transmission failed. Launching client mail window fallback...');
            const subject = encodeURIComponent(`Secure Transmission from ${name}`);
            const body = encodeURIComponent(`Identity: ${name}\nReturn Vector: ${email}\n\nTransmission:\n${message}`);
            window.location.href = `mailto:keerthivasanm.student@saveetha.ac.in?subject=${subject}&body=${body}`;
          } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
          }
        });
      }

      // Browser Fingerprinting script
      const agentEl = document.getElementById('metric-agent');
      const ipGeoEl = document.getElementById('metric-ip-geo');
      const resEl = document.getElementById('metric-resolution');
      const viewportEl = document.getElementById('metric-viewport');
      const tzEl = document.getElementById('metric-timezone');
      const langEl = document.getElementById('metric-lang');
      const coresEl = document.getElementById('metric-cores');
      const ramEl = document.getElementById('metric-ram');
      const gpuEl = document.getElementById('metric-gpu');
      const networkEl = document.getElementById('metric-network');
      const themePrefEl = document.getElementById('metric-theme-pref');
      const batteryEl = document.getElementById('metric-battery');
      const deviceClassEl = document.getElementById('metric-device-class');
      const integrityEl = document.getElementById('metric-integrity');
      const hashEl = document.getElementById('metric-hash');

      let gpuInfo = "UNAVAILABLE";
      try {
        const canvas = document.createElement('canvas');
        const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
        if (gl) {
          const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
          if (debugInfo) {
            gpuInfo = gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL);
          } else {
            gpuInfo = gl.getParameter(gl.RENDERER);
          }
        }
      } catch(e) {
        gpuInfo = "RESTRICTED";
      }

      if (agentEl) {
        const ua = navigator.userAgent;
        let os = "Unknown OS";
        if (ua.indexOf("Win") !== -1) os = "Windows";
        else if (ua.indexOf("Mac") !== -1) os = "macOS";
        else if (ua.indexOf("X11") !== -1) os = "UNIX";
        else if (ua.indexOf("Linux") !== -1) os = "Linux";
        else if (/Android/i.test(ua)) os = "Android";
        else if (/iPhone|iPad/i.test(ua)) os = "iOS";

        let browser = "Unknown Browser";
        if (ua.indexOf("Chrome") !== -1) browser = "Chrome";
        else if (ua.indexOf("Firefox") !== -1) browser = "Firefox";
        else if (ua.indexOf("Safari") !== -1) browser = "Safari";
        else if (ua.indexOf("Edge") !== -1) browser = "Edge";

        agentEl.textContent = `${os} / ${browser}`;
      }

      // Live Viewport size detection
      const updateViewport = () => {
        if (viewportEl) {
          viewportEl.textContent = `${window.innerWidth}x${window.innerHeight} (px)`;
        }
      };
      updateViewport();
      window.addEventListener('resize', updateViewport);

      // Fetch IP Gateway & Geolocation
      if (ipGeoEl) {
        fetch('https://ipapi.co/json/')
          .then(res => res.json())
          .then(data => {
            if (data.ip) {
              ipGeoEl.textContent = `${data.ip} (${data.city || 'Unknown'}, ${data.country_code || 'IN'})`;
            } else {
              ipGeoEl.textContent = "PRIVATE GATEWAY";
            }
          })
          .catch(() => {
            ipGeoEl.textContent = "PRIVATE GATEWAY / BLOCKED";
          });
      }

      // Display Mode & Theme Preference
      const updateThemePref = () => {
        if (themePrefEl) {
          const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const isStandalone = window.matchMedia('(display-mode: standalone)').matches;
          themePrefEl.textContent = `${isDark ? 'DARK MODE' : 'LIGHT MODE'} / ${isStandalone ? 'PWA_STANDALONE' : 'BROWSER_TAB'}`;
        }
      };
      updateThemePref();
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', updateThemePref);

      // Power Vector & Battery Level
      if (batteryEl) {
        // @ts-ignore
        if ('getBattery' in navigator) {
          // @ts-ignore
          navigator.getBattery().then(battery => {
            const updateBattery = () => {
              batteryEl.textContent = `${Math.round(battery.level * 100)}% (${battery.charging ? 'CHARGING' : 'DISCHARGING'})`;
            };
            updateBattery();
            battery.addEventListener('levelchange', updateBattery);
            battery.addEventListener('chargingchange', updateBattery);
          }).catch(() => {
            batteryEl.textContent = "UNSUPPORTED / RESTRICTED";
          });
        } else {
          batteryEl.textContent = "UNSUPPORTED (SAFARI/FIREFOX)";
        }
      }

      // Input Vector & Device Class
      if (deviceClassEl) {
        const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
        const width = window.screen.width;
        let devClass = 'DESKTOP';
        if (/Mobi|Android|iPhone|iPad/i.test(navigator.userAgent)) {
          devClass = isTouch && width < 768 ? 'MOBILE_HANDSET' : 'TABLET_DEVICE';
        } else if (isTouch) {
          devClass = 'TOUCH_LAPTOP';
        }
        deviceClassEl.textContent = `${devClass} (${isTouch ? 'TOUCH' : 'MOUSE'} INPUT)`;
      }

      if (resEl) {
        resEl.textContent = `${window.screen.width}x${window.screen.height} (${window.devicePixelRatio}dppx)`;
      }

      if (tzEl) {
        try {
          tzEl.textContent = Intl.DateTimeFormat().resolvedOptions().timeZone || "UTC/Greenwich";
        } catch(e) {
          tzEl.textContent = "UTC/Greenwich";
        }
      }

      if (langEl) {
        langEl.textContent = (navigator.language || 'en-US').toUpperCase();
      }

      if (coresEl) {
        coresEl.textContent = navigator.hardwareConcurrency ? `${navigator.hardwareConcurrency} Logical Cores` : "UNAVAILABLE";
      }

      if (ramEl) {
        // @ts-ignore
        ramEl.textContent = navigator.deviceMemory ? `~ ${navigator.deviceMemory} GB RAM` : "RESTRICTED / UNAVAILABLE";
      }

      if (gpuEl) {
        gpuEl.textContent = gpuInfo.replace("ANGLE (", "").replace(" vs_", "").substring(0, 35);
      }

      if (networkEl) {
        let netInfo = "UNKNOWN/OFFLINE";
        if (navigator.onLine) {
          // @ts-ignore
          const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
          if (conn) {
            const rtt = conn.rtt ? `${conn.rtt}ms RTT` : "unknown latency";
            const downlink = conn.downlink ? `${conn.downlink} Mbps` : "unknown bandwidth";
            const type = conn.effectiveType ? `(${conn.effectiveType.toUpperCase()})` : "";
            netInfo = `${downlink} / ${rtt} ${type}`;
          } else {
            netInfo = "ONLINE (TELEMETRY_RESTRICTED)";
          }
        } else {
          netInfo = "OFFLINE";
        }
        networkEl.textContent = netInfo;
      }

      if (integrityEl) {
        const cookieActive = navigator.cookieEnabled ? "COOKIES_ON" : "COOKIES_OFF";
        // @ts-ignore
        const dntActive = (navigator.doNotTrack === "1" || navigator.doNotTrack === "yes" || window.doNotTrack === "1") ? "DNT_ON" : "DNT_OFF";
        const onlineStatus = navigator.onLine ? "ONLINE" : "OFFLINE";
        integrityEl.textContent = `${onlineStatus} • ${cookieActive} • ${dntActive}`;
      }

      if (hashEl) {
        // @ts-ignore
        const fingerprintStr = navigator.userAgent + (navigator.language || 'en-US') + window.screen.width + window.screen.height + (Intl.DateTimeFormat().resolvedOptions().timeZone || "") + (navigator.hardwareConcurrency || "") + (navigator.deviceMemory || "") + gpuInfo;
        
        let hash = 5381;
        for (let i = 0; i < fingerprintStr.length; i++) {
          hash = (hash * 33) ^ fingerprintStr.charCodeAt(i);
        }
        const hexHash = Math.abs(hash).toString(16).toUpperCase().padStart(8, '0');
        hashEl.textContent = `0x${hexHash}-FP-ACTIVE`;
      }
    });
  </script>
</Layout>
