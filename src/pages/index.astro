---
import Layout from '../layouts/Layout.astro';
import HeroConsole from '../components/HeroConsole.jsx';
import RadarTechGrid from '../components/RadarTechGrid.jsx';
import EncryptedProjectCards from '../components/EncryptedProjectCards.jsx';

const web3formsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || '';


const timelineEvents = [
  {
    year: 'Jun 2026 - Jul 2026',
    event: 'Cyber Security Intern (Malware Analysis)',
    org: 'Tamil Nadu Cyber Crime Wing',
    logoId: 'tn_cyber',
    desc: 'Reduced application triage time by 80% (hours to minutes), automated malicious infrastructure extraction, and contributed to a 40% backlog reduction for state-level law enforcement.'
  },
  {
    year: 'Nov 2025',
    event: 'Security Lead',
    org: 'High-Traffic Web Platform, SEC',
    logoId: 'sec_platform',
    desc: 'Led security design for 6,000+ users and 50,000+ requests, implementing OWASP Top 10 controls and traffic log analysis.'
  },
  {
    year: 'Jan 2025 - Feb 2025',
    event: 'SOC Analyst Intern',
    org: 'Zybeak Technologies',
    logoId: 'zybeak',
    desc: 'Monitored high-volume telemetry, tuned SIEM rules reducing false positives by 30%, and automated log parsing with Python/Bash.'
  },
  {
    year: '2023 - 2027',
    event: 'BE - Cyber Security',
    org: 'Saveetha Engineering College',
    logoId: 'sec_college',
    desc: 'Bachelor of Engineering in Cyber Security. Rigorous coursework covering Cryptography, Cloud Security, and Secure Systems Design.'
  }
];
---

<Layout>
  <!-- Main Header Bar -->
  <header class="sticky top-0 z-[100] border-b border-white/[0.04] bg-[#050811]/75 backdrop-blur-xl select-none font-mono">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="#" class="font-mono text-sm tracking-wider flex items-center gap-2.5 group text-white uppercase select-none">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#00F0FF]/75 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#00F0FF]"></span>
        </span>
        <span class="tracking-[0.16em] font-extrabold text-xs text-neutral-200 group-hover:text-white transition-colors">KEERTHIVASAN M</span>
      </a>
      <nav class="hidden md:flex gap-8 text-[10px] font-bold uppercase tracking-wider text-neutral-400">
        <a href="#profile" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1 group/nav relative py-1">
          <span class="absolute left-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform -translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">[</span>
          PROFILE
          <span class="absolute right-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">]</span>
        </a>
        <a href="#arsenal" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1 group/nav relative py-1">
          <span class="absolute left-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform -translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">[</span>
          ARSENAL
          <span class="absolute right-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">]</span>
        </a>
        <a href="#projects" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1 group/nav relative py-1">
          <span class="absolute left-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform -translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">[</span>
          PROJECTS
          <span class="absolute right-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">]</span>
        </a>
        <a href="#timeline" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1 group/nav relative py-1">
          <span class="absolute left-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform -translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">[</span>
          LOGS
          <span class="absolute right-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">]</span>
        </a>
        <a href="#contact" class="hover:text-[#00F0FF] transition-colors flex items-center gap-1 group/nav relative py-1">
          <span class="absolute left-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform -translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">[</span>
          CONTACT
          <span class="absolute right-[-8px] opacity-0 group-hover/nav:opacity-100 transition-all duration-300 transform translate-x-1 group-hover/nav:translate-x-0 text-[#00F0FF]">]</span>
        </a>
      </nav>
    </div>
  </header>

  <!-- Hero Landing Section -->
  <section id="about" class="border-b border-white/[0.04] overflow-hidden">
    <HeroConsole client:load />
  </section>

  <!-- About Me & Certifications Section -->
  <section id="profile" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.04] overflow-hidden">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      <div class="lg:col-span-8 space-y-6">
        <div class="inline-flex">
          <span class="bg-[#00F0FF]/5 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/15 select-none">
            01 // PROFILE SUMMARY
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-4 font-sans">
          Decrypted <span class="text-[#00F0FF]">Operator</span> Profile
        </h2>
        <p class="text-sm sm:text-base text-neutral-400 font-mono leading-relaxed border-l-2 border-white/10 pl-6 py-2">
          Detection-focused cybersecurity engineer and security researcher specializing in threat detection, incident response, and malware forensics. Hands-on experience in SOC operations, SIEM rules tuning (Splunk, Elastic, Sentinel), and security telemetry analytics. Expert in auditing application and network infrastructures, implementing OWASP Top 10 mitigations, and automating defensive workflows with Python, Bash, and Go. Passionate about reverse engineering binaries, threat modeling, cloud security architecture (AWS/GCP), and building highly resilient production environments. Committed to bridge the gap between development and security operation centers through rigorous DevSecOps pipelines and proactive threat hunting.
        </p>
        

      </div>

      <div class="lg:col-span-4 space-y-6">
        <div class="inline-flex">
          <span class="bg-[#00F0FF]/5 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/15 select-none">
            VERIFIED_CREDS
          </span>
        </div>
        <h3 class="text-lg font-bold tracking-tight text-white font-sans uppercase">
          Certifications
        </h3>
        
        <div class="space-y-4">
          {/* Google Cybersecurity Certificate */}
          <div class="glass-panel p-4 rounded-2xl border border-white/5 bg-black/10 flex items-center gap-4 hover:border-[#00F0FF]/30 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.85z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.85c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xs font-bold text-white uppercase tracking-wider font-mono">Google Professional</h4>
              <p class="text-[10px] text-neutral-500 font-mono mt-0.5">Cybersecurity Certificate</p>
            </div>
          </div>

          {/* AWS Cloud Solutions Architect */}
          <div class="glass-panel p-4 rounded-2xl border border-white/5 bg-black/10 flex items-center gap-4 hover:border-[#00F0FF]/30 transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
              <svg class="w-8 h-8" viewBox="0 20 128 88" fill="none">
                <path fill="#FFFFFF" d="M36.379 53.64c0 1.56.168 2.825.465 3.75.336.926.758 1.938 1.347 3.032.207.336.293.672.293.969 0 .418-.254.84-.8 1.261l-2.653 1.77c-.379.25-.758.379-1.093.379-.422 0-.844-.211-1.266-.59a13.28 13.28 0 0 1-1.516-1.98 34.153 34.153 0 0 1-1.304-2.485c-3.282 3.875-7.41 5.813-12.38 5.813-3.535 0-6.355-1.012-8.421-3.032-2.063-2.023-3.114-4.718-3.114-8.086 0-3.578 1.262-6.484 3.833-8.671 2.566-2.192 5.976-3.286 10.316-3.286 1.43 0 2.902.125 4.46.336 1.56.211 3.161.547 4.845.926v-3.074c0-3.2-.676-5.43-1.98-6.734C26.061 32.633 23.788 32 20.546 32c-1.473 0-2.988.168-4.547.547a33.416 33.416 0 0 0-4.547 1.433c-.676.293-1.18.461-1.473.547-.296.082-.507.125-.675.125-.59 0-.883-.422-.883-1.304v-2.063c0-.676.082-1.18.293-1.476.21-.293.59-.586 1.18-.883 1.472-.758 3.242-1.39 5.304-1.895 2.063-.547 4.254-.8 6.57-.8 5.008 0 8.672 1.136 11.032 3.41 2.316 2.273 3.492 5.726 3.492 10.359v13.64Zm-17.094 6.403c1.387 0 2.82-.254 4.336-.758 1.516-.508 2.863-1.433 4-2.695.672-.8 1.18-1.684 1.43-2.695.254-1.012.422-2.23.422-3.665v-1.765a34.401 34.401 0 0 0-3.871-.719 31.816 31.816 0 0 0-3.961-.25c-2.82 0-4.883.547-6.274 1.684-1.387 1.136-2.062 2.734-2.062 4.84 0 1.98.504 3.453 1.558 4.464 1.012 1.051 2.485 1.559 4.422 1.559Zm33.809 4.547c-.758 0-1.262-.125-1.598-.422-.34-.254-.633-.84-.887-1.64L40.715 29.98c-.25-.843-.38-1.39-.38-1.687 0-.672.337-1.05 1.013-1.05h4.125c.8 0 1.347.124 1.644.421.336.25.59.84.84 1.64l7.074 27.876 6.57-27.875c.208-.84.462-1.39.797-1.64.34-.255.93-.423 1.688-.423h3.367c.8 0 1.348.125 1.684.422.336.25.633.84.8 1.64l6.653 28.212 7.285-28.211c.25-.84.547-1.39.84-1.64.336-.255.887-.423 1.644-.423h3.914c.676 0 1.055.336 1.055 1.051 0 .21-.043.422-.086.676-.043.254-.125.59-.293 1.05L80.801 62.57c-.254.84-.547 1.387-.887 1.64-.336.255-.883.423-1.598.423h-3.62c-.801 0-1.348-.13-1.684-.422-.34-.297-.633-.844-.801-1.684l-6.527-27.16-6.485 27.117c-.21.844-.46 1.391-.8 1.684-.337.297-.926.422-1.684.422Zm54.105 1.137c-2.187 0-4.379-.254-6.484-.758-2.106-.504-3.746-1.055-4.84-1.684-.676-.379-1.137-.8-1.305-1.18a2.919 2.919 0 0 1-.254-1.18v-2.148c0-.882.336-1.304.97-1.304.25 0 .503.043.757.129.25.082.629.25 1.05.418a23.102 23.102 0 0 0 4.634 1.476c1.683.336 3.324.504 5.011.504 2.653 0 4.715-.465 6.145-1.39 1.433-.926 2.191-2.274 2.191-4 0-1.18-.379-2.145-1.136-2.946-.758-.8-2.192-1.516-4.254-2.191l-6.106-1.895c-3.074-.969-5.348-2.398-6.734-4.293-1.39-1.855-2.106-3.918-2.106-6.105 0-1.77.38-3.328 1.137-4.676a10.829 10.829 0 0 1 3.031-3.453c1.262-.965 2.696-1.684 4.38-2.188 1.683-.504 3.452-.715 5.304-.715.926 0 1.894.043 2.82.168.969.125 1.852.293 2.738.461.84.211 1.641.422 2.399.676.758.254 1.348.504 1.77.758.59.336 1.011.672 1.261 1.05.254.34.379.802.379 1.391v1.98c0 .884-.336 1.348-.969 1.348-.336 0-.883-.171-1.597-.507-2.403-1.094-5.098-1.641-8.086-1.641-2.399 0-4.293.379-5.598 1.18-1.309.797-1.98 2.02-1.98 3.746 0 1.18.421 2.191 1.261 2.988.844.8 2.403 1.602 4.633 2.316l5.98 1.895c3.032.969 5.22 2.316 6.524 4.043 1.305 1.727 1.938 3.707 1.938 5.895 0 1.812-.38 3.453-1.094 4.882-.758 1.434-1.77 2.696-3.074 3.707-1.305 1.051-2.864 1.809-4.672 2.36-1.895.586-3.875.883-6.024.883Zm0 0" />
                <path fill="#FF9900" d="M118 73.348c-4.432.063-9.664 1.052-13.621 3.832-1.223.883-1.012 2.062.336 1.894 4.508-.547 14.44-1.726 16.21.547 1.77 2.23-1.976 11.62-3.663 15.79-.504 1.26.59 1.769 1.726.8 7.41-6.231 9.348-19.242 7.832-21.137-.757-.925-4.388-1.79-8.82-1.726zM1.63 75.859c-.927.116-1.347 1.236-.368 2.121 16.508 14.902 38.359 23.872 62.613 23.872 17.305 0 37.43-5.43 51.281-15.66 2.273-1.688.297-4.254-2.02-3.204-15.534 6.57-32.421 9.77-47.788 9.77-22.778 0-44.8-6.273-62.653-16.633-.39-.231-.755-.304-1.064-.266z" />
              </svg>
            </div>
            <div>
              <h4 class="text-xs font-bold text-white uppercase tracking-wider font-mono">AWS Certified</h4>
              <p class="text-[10px] text-neutral-500 font-mono mt-0.5">Solutions Architect</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Arsenal Section -->
  <section id="arsenal" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.04] overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/5 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/15 select-none">
            02 // CAPABILITIES
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Tooling <span class="text-[#00F0FF]">&</span> Secure Arsenal
        </h2>
      </div>
      <RadarTechGrid client:load />
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section id="projects" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.04] overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/5 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/15 select-none">
            03 // SECURED VAULTS
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Secured <span class="text-[#00F0FF]">Dossiers</span> & Projects
        </h2>
      </div>
      <EncryptedProjectCards client:load />
    </div>
  </section>

  <!-- Secure Log Timeline Section -->
  <section id="timeline" class="relative py-24 px-6 sm:px-12 md:px-24 border-b border-white/[0.04] overflow-hidden">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16">
        <div class="inline-flex mb-4">
          <span class="bg-[#00F0FF]/5 text-[#00F0FF] px-3.5 py-1 rounded-full font-mono text-[9px] uppercase font-bold tracking-widest border border-[#00F0FF]/15 select-none">
            04 // CHRONOLOGY
          </span>
        </div>
        <h2 class="text-3xl sm:text-5xl font-black tracking-tight text-white mb-2 font-sans">
          Milestones <span class="text-[#00F0FF]">&</span> Timeline
        </h2>
      </div>

      <!-- Log Timeline Core (Alternating Layout) -->
      <div class="relative max-w-5xl mx-auto px-4 overflow-hidden">
        <!-- Central Line (Desktop Only, Left-aligned on Mobile) -->
        <div class="absolute left-6 md:left-1/2 md:-translate-x-1/2 top-2 bottom-2 w-[2px] bg-white/5">
          <div class="traceroute-line w-full bg-[#00F0FF]/60 shadow-[0_0_8px_rgba(0,240,255,0.4)]" style="height: 0%;"></div>
        </div>

        <div class="space-y-16">
          {timelineEvents.map((log, index) => {
            const isLeft = index % 2 === 0;
            return (
              <div class={`timeline-event opacity-25 flex flex-col md:flex-row items-center w-full relative ${isLeft ? 'md:justify-start' : 'md:justify-end'}`}>
              <!-- Center Node Dot -->
              <div class="absolute left-6 md:left-1/2 -translate-x-1/2 top-6 md:top-1/2 md:-translate-y-1/2 bg-[#050811] border border-white/20 w-4 h-4 rounded-full flex items-center justify-center z-10 transition-all duration-300">
                <div class="w-1.5 h-1.5 bg-[#00F0FF] rounded-full"></div>
              </div>

              <!-- Event Card Container -->
              <div class={`w-full md:w-[45%] pl-12 md:pl-0 ${isLeft ? 'md:pr-8' : 'md:pl-8'}`}>
                <div class="glass-panel p-6 sm:p-8 border border-white/5 rounded-3xl bg-black/10 hover:border-[#00F0FF]/20 transition-all duration-500 hover:scale-[1.02] flex flex-col md:flex-row gap-5 items-start">
                  
                  {/* Company/Org Logo Vector Badge */}
                  <div class="w-14 h-14 shrink-0 rounded-2xl bg-white/[0.02] border border-white/10 flex items-center justify-center relative overflow-hidden group/logo hover:border-[#00F0FF]/30 transition-all duration-300">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#00F0FF]/5 to-transparent opacity-0 group-hover/logo:opacity-100 transition-opacity"></div>
                    
                    {log.logoId === 'tn_cyber' && (
                      <svg class="w-8 h-8 text-[#00F0FF]" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M32 4L52 14V32C52 46 32 58 32 58C32 58 12 46 12 32V14L32 4Z" fill="url(#tn_grad)" stroke="#00F0FF" stroke-width="2"/>
                        <path d="M26 40h12v-3H26v3zm1-3h10v-5H27v5zm2-5h6v-5h-6v5zm1.5-5h3v-4h-3v4z" fill="none" stroke="#FFCC00" stroke-width="1.5"/>
                        <text x="32" y="50" font-family="monospace" font-weight="900" font-size="8" fill="#FFFFFF" text-anchor="middle" letter-spacing="0.5">TNP</text>
                        <defs>
                          <linearGradient id="tn_grad" x1="32" y1="4" x2="32" y2="58" gradientUnits="userSpaceOnUse">
                            <stop offset="0%" stop-color="#00F0FF" stop-opacity="0.1"/>
                            <stop offset="100%" stop-color="#1E40AF" stop-opacity="0.3"/>
                          </linearGradient>
                        </defs>
                      </svg>
                    )}
                    
                    {log.logoId === 'sec_platform' && (
                      <svg class="w-8 h-8 text-[#00F0FF]" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="32" cy="32" r="24" fill="url(#platform_grad)" stroke="#00F0FF" stroke-width="2"/>
                        <path d="M32 8v48M8 32h48" stroke="#00F0FF" stroke-width="1" stroke-opacity="0.5"/>
                        <path d="M14 20c8-3 12-3 20 0M14 44c8 3 12 3 20 0" stroke="#00F0FF" stroke-width="1" stroke-opacity="0.5"/>
                        <path d="M20 14c3 8 3 12 0 20M44 14c-3 8-3 12 0 20" stroke="#00F0FF" stroke-width="1" stroke-opacity="0.5"/>
                        <rect x="25" y="28" width="14" height="12" rx="2" fill="#050811" stroke="#FFCC00" stroke-width="2"/>
                        <path d="M28 28V24c0-2.2 1.8-4 4-4s4 1.8 4 4v4" stroke="#FFCC00" stroke-width="2"/>
                        <defs>
                          <linearGradient id="platform_grad" x1="32" y1="8" x2="32" y2="56" gradientUnits="userSpaceOnUse">
                            <stop offset="0%" stop-color="#00F0FF" stop-opacity="0.1"/>
                            <stop offset="100%" stop-color="#1E40AF" stop-opacity="0.3"/>
                          </linearGradient>
                        </defs>
                      </svg>
                    )}
                    
                    {log.logoId === 'zybeak' && (
                      <svg class="w-8 h-8 text-[#00F0FF]" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M16 16h32L24 40h24" stroke="#00F0FF" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M12 28L8 44l16-4-8-12z" fill="#1E40AF" fill-opacity="0.3" stroke="#00F0FF" stroke-width="1"/>
                        <path d="M52 36l4-16-16 4 12 12z" fill="#1E40AF" fill-opacity="0.3" stroke="#00F0FF" stroke-width="1"/>
                      </svg>
                    )}
                    
                    {log.logoId === 'sec_college' && (
                      <svg class="w-8 h-8 text-[#00F0FF]" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M32 6l20 8v16c0 14-20 24-20 24S12 44 12 30V14l20-8z" fill="url(#sec_grad)" stroke="#00F0FF" stroke-width="2" />
                        <text x="32" y="38" font-family="monospace" font-weight="900" font-size="12" fill="#FFFFFF" text-anchor="middle" letter-spacing="0.5">SEC</text>
                        <path d="M20 18l12-5 12 5-12 5-12-5z" fill="#FF9900" stroke="#FF9900" stroke-width="1" />
